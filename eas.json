{
  "cli": {
    "version": ">= 15.0.12",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "development",
        "ANDROID_PACKAGE": "site.jagged.planneriti.dev",
        "IOS_BUNDLE_IDENTIFIER": "site.jagged.planneriti.dev",
        "RUNTIME_VERSION": "1.5.0-dev.1"
      }
    },
    "beta": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "beta",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "beta",
        "ANDROID_PACKAGE": "site.jagged.planneriti.beta",
        "IOS_BUNDLE_IDENTIFIER": "site.jagged.planneriti.beta",
        "RUNTIME_VERSION": "1.5.0-beta.1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "production",
        "ANDROID_PACKAGE": "site.jagged.planneriti",
        "IOS_BUNDLE_IDENTIFIER": "site.jagged.planneriti",
        "RUNTIME_VERSION": "1.5.0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}