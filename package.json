{
  "name": "planneriti",
  "main": "expo-router/entry",
  "version": "1.4.0",
  "scripts": {
    "start": "expo start --clear",
    "start:dev-client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "build": "eas build --profile production --platform android",
    "build:ios": "eas build --profile production --platform ios",
    "build:dev": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:local": "eas build --profile development --platform android --local",
    "build:dev:local:ios": "eas build --profile development --platform ios --local",
    "update": "eas update --channel production --platform android",
    "update:ios": "eas update --channel production --platform ios",
    "build:apks": "node scripts/build-apks.js"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/dom-webview": "~56.0.5",
    "@expo/metro-runtime": "~56.0.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-vector-icons/feather": "^13.1.1",
    "@react-native-vector-icons/fontawesome": "^13.1.1",
    "@react-native-vector-icons/ionicons": "^13.1.1",
    "@react-native-vector-icons/material-icons": "^13.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "expo": "56.0.0-preview.12",
    "expo-application": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.11",
    "expo-dev-client": "~56.0.11",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.8",
    "expo-navigation-bar": "~56.0.3",
    "expo-notifications": "~56.0.9",
    "expo-print": "~56.0.3",
    "expo-router": "~56.2.1",
    "expo-secure-store": "~56.0.3",
    "expo-sharing": "~56.0.9",
    "expo-splash-screen": "~56.0.7",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.4",
    "expo-updates": "~56.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-worklets": "0.8.3",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "pnpm": {
    "overrides": {
      "react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@11.1.2",
  "private": true
